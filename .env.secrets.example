# GitHub Actions secrets - copy to .env.secrets and fill in real values
# Run ./scripts/push-secrets.sh to sync to GitHub
#
# .env.secrets is gitignored and will never be committed

# OCI VM SSH access
OCI_HOST=         # public IP or hostname of the OCI VM
OCI_USER=ubuntu   # SSH username
OCI_SSH_KEY_FILE=~/.ssh/id_ed25519  # path to SSH private key file (contents will be uploaded, not the path)

# Proxy access
PROXY_DOMAIN=     # public domain, e.g. proxy.yourdomain.com
PROXY_API_KEY=    # API key (same value as PROXY_API_KEY on the server)
