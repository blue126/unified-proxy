# GitHub Actions secrets — 复制为 .env.secrets 并填入真实值
# 用 ./scripts/push-secrets.sh 同步到 GitHub
#
# .env.secrets 已加入 .gitignore，不会提交到仓库

# OCI VM SSH 访问
OCI_HOST=         # OCI VM 公网 IP 或域名
OCI_USER=ubuntu   # SSH 用户名
OCI_SSH_KEY_FILE=~/.ssh/id_ed25519      # SSH 私钥文件路径（内容会被读取后上传，非 OCI API Key）

# 代理访问
PROXY_DOMAIN=     # 代理公开域名，如 proxy.yourdomain.com
PROXY_API_KEY=    # 代理 API Key（与服务器 .env 里的 PROXY_API_KEY 相同）
